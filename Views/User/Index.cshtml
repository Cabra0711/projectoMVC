@model IEnumerable<EventosTematicos.Models.Evento>

<section class="hero text-center mt-4">
    <div class="container">
        <h1 class="display-4 fw-bold">No te pierdas el proximo conciento!</h1>
        <p class="fs-4">Explora los <span class="text-warning">eventos mas emocionantes</span> pasando localmente.</p>

        <div class="search-bar d-flex align-items-center shadow mt-4">
            <i class="bi bi-search text-muted me-2"></i>
            <input type="text" class="form-control border-0 shadow-none" placeholder="Busca Eventos, Categorias, Ubicacion...">
            <div class="vr mx-3"></div>
            <i class="bi bi-geo-alt text-muted me-2"></i>
            <select class="form-select border-0 shadow-none w-auto">
                <option>Medellin</option>
                <option>Bogotá</option>
            </select>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Eventos en MEDELLÍN</h3>
        <div class="btn-group border rounded-pill p-1 bg-white shadow-sm">
            <button class="btn btn-sm btn-dark rounded-pill px-3">TODOS</button>
            <button class="btn btn-sm btn-light rounded-pill px-3">HOY</button>
            <button class="btn btn-sm btn-light rounded-pill px-3">GRATIS</button>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var evento in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 card-event border-0 shadow-sm position-relative" style="border-radius: 15px; overflow: hidden;">
                    <div class="position-relative">
                        <img src="@evento.UrlImagen" class="card-img-top" style="height: 220px; object-fit: cover;">
                        <span class="position-absolute bottom-0 start-0 m-2 badge" style="background-color: #FFD700; color: #000; padding: 8px 12px; font-weight: 800;">
                            Concierto Musical
                        </span>
                    </div>

                    <div class="card-body d-flex pt-4 h-100 d-flex flex-column mt-auto">
                        <div class="date-box text-center mb-2">
                            <span class="text-primary fw-bold small text-uppercase">@evento.Fecha.ToString("MMM")</span><br>
                            <span class="h4 fw-bold">@evento.Fecha.ToString("dd")</span><br>
                        </div>
                        <div class="ps-3 w-100">
                            <h6 class="fw-bold mb-1 text-uppercase h4">@evento.Ubicacion</h6>
                            <p class="text-muted small mb-2 text-truncate overflow-hidden" style="-webkit-line-clamp: 3;">@evento.Descripcion</p>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="fw-bold text-dark">COP @evento.Precio.ToString("N0")</span>
                                <span class="small text-secondary"><i class="bi bi-clock me-1"></i>HORA INICIO: @evento.HoraInicio</span>
                                <span class="small text-secondary"><i class="bi bi-clock me-1"></i>HORA FINAL: @evento.HoraFin</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>