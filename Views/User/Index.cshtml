@model IEnumerable<EventosTematicos.Models.Evento>

<section class="hero text-center mt-4">
    <div class="container">
        <h1 class="display-4 fw-bold">No te pierdas el proximo conciento!</h1>
        <p class="fs-4">Explora los <span class="text-warning">eventos mas emocionantes</span> pasando localmente.</p>
            
        <div class="search-bar d-flex align-items-center shadow mt-4">
            <i class="bi bi-search text-muted me-2"></i>
            <input type="text" class="form-control border-0 shadow-none" placeholder="Busca Eventos, Categorias, Ubicacion...">
            <div class="vr mx-3"></div>
            <i class="bi bi-geo-alt text-muted me-2"></i>
            <select class="form-select border-0 shadow-none w-auto">
                <option>Medellin</option>
                <option>Bogotá</option>
            </select>
        </div>
    </div>
</section>

<section class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold">Eventos en MEDELLÍN</h3>
            <div class="btn-group border rounded-pill p-1 bg-white shadow-sm">
                <button class="btn btn-sm btn-dark rounded-pill px-3">TODOS</button>
                <button class="btn btn-sm btn-light rounded-pill px-3">HOY</button>
                <button class="btn btn-sm btn-light rounded-pill px-3">GRATIS</button>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 card-event border-0 shadow-sm position-relative" style="border-radius: 15px; overflow: hidden;">
                    
                    <div class="position-absolute top-0 end-0 m-2 d-flex flex-column gap-2" style="z-index: 10;">
                        <button class="btn shadow-sm d-flex align-items-center justify-content-center" 
                                data-bs-toggle="modal" data-bs-target="#createEventModal"
                                style="width: 35px; height: 35px; border-radius: 50%; border: none; background-color: white;">
                            <i class="bi bi-pencil-fill" style="color: #0d6efd;"></i>
                        </button>
                        <button class="btn shadow-sm d-flex align-items-center justify-content-center" 
                                data-bs-toggle="modal" data-bs-target="#deleteEventModal"
                                style="width: 35px; height: 35px; border-radius: 50%; border: none; background-color: white;">
                            <i class="bi bi-trash3-fill" style="color: #dc3545;"></i>
                        </button>
                    </div>

                    <div class="position-relative">
                        <img src="https://www.streetartlatam.com/_next/image?url=https%3A%2F%2Fstreetartlatam.s3.amazonaws.com%2Fproduction%2Fmedium_Arcangel_impulsa_nuevos_jovenes_talentos_9bcf368780.jpg&w=1920&q=75" 
                             class="card-img-top" style="height: 220px; object-fit: cover;">
                        <span class="position-absolute bottom-0 start-0 m-2 badge" style="background-color: #FFD700; color: #000; padding: 8px 12px; font-weight: 800;">
                            Concierto Musical
                        </span>
                    </div>

                    <div class="card-body d-flex pt-4">
                        <div class="date-box pe-3">
                            <span class="text-primary fw-bold small">ABR</span><br>
                            <span class="h4 fw-bold">25</span>
                        </div>
                        <div class="ps-3 w-100">
                            <h6 class="fw-bold mb-1">ATANASIO GIRARDOT</h6>
                            <p class="text-muted small mb-2 text-truncate">Vive una noche de maravilla con Arcángel.</p>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="fw-bold text-dark">COP 250,000</span>
                                <span class="small text-secondary"><i class="bi bi-clock me-1"></i>9:30 PM</span>
                            </div>
                        </div>
                    </div>
                </div>
                @foreach (var evento in Model)
                {
                    <div class="card h-100 card-event border-0 shadow-sm position-relative" style="border-radius: 15px; overflow: hidden;">
                    
                    <div class="position-absolute top-0 end-0 m-2 d-flex flex-column gap-2" style="z-index: 10;">
                        <button class="btn shadow-sm d-flex align-items-center justify-content-center" 
                                data-bs-toggle="modal" data-bs-target="#createEventModal"
                                style="width: 35px; height: 35px; border-radius: 50%; border: none; background-color: white;">
                            <i class="bi bi-pencil-fill" style="color: #0d6efd;"></i>
                        </button>
                        <button class="btn shadow-sm d-flex align-items-center justify-content-center" 
                                data-bs-toggle="modal" data-bs-target="#deleteEventModal"
                                style="width: 35px; height: 35px; border-radius: 50%; border: none; background-color: white;">
                            <i class="bi bi-trash3-fill" style="color: #dc3545;"></i>
                        </button>
                    </div>

                    <div class="position-relative">
                        <img src="@evento.UrlImagen" 
                             class="card-img-top" style="height: 220px; object-fit: cover;">
                        <span class="position-absolute bottom-0 start-0 m-2 badge" style="background-color: #FFD700; color: #000; padding: 8px 12px; font-weight: 800;">
                            Concierto Musical
                        </span>
                    </div>

                    <div class="card-body d-flex pt-4">
                        <div class="date-box pe-3">
                            <span class="text-primary fw-bold small">@evento.Fecha</span><br>
                        </div>
                        <div class="ps-3 w-100">
                            <h6 class="fw-bold mb-1">@evento.Ubicacion</h6>
                            <p class="text-muted small mb-2 text-truncate">@evento.Descripcion</p>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="fw-bold text-dark">COP @evento.Precio</span>
                                <span class="small text-secondary"><i class="bi bi-clock me-1"></i>@evento.HoraInicio - @evento.HoraFin</span>
                            </div>
                        </div>
                    </div>
                </div>
                }
            </div>
            </div>
    </section>