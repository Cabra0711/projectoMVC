<div class="mt-4  ">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pe-4">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pb-4">
                <div class="display-4 text-danger mb-3">
                    <i class="bi bi-exclamation-octagon-fill"></i>
                </div>
                <h3 class="fw-bold">¿Estás seguro?</h3>
                <p class="text-muted">Esta acción no se puede deshacer. El evento <strong id="eventNameDisplay"></strong> será eliminado.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center pb-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                <form id="deleteForm" method="post" asp-action="Delete" asp-route-id="Id">
                    <input type="hidden" name="id" id="DeleteId"/>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Sí, Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>