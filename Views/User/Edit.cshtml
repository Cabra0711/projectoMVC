@model EventosTematicos.Models.Evento

<section class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 p-4">
                <div class="d-flex align-items-center mb-4">
                    <a asp-action="Admin" class="btn btn-light rounded-circle me-3">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <h2 class="fw-bold mb-0 border-bottom pb-2 flex-grow-1">Editar Evento</h2>
                </div>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3 mb-3 justify-content-center">
                        <div class="col-md-8">
                            <label asp-for="Nombre" class="form-label fw-bold">Nombre del Evento</label>
                            <input asp-for="Nombre" type="text" class="form-control rounded-pill" placeholder="Ej: Arcángel en Medellín">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UrlImagen" class="form-label fw-bold">URL del Banner</label>
                        <div class="input-group">
                            <span  class="input-group-text bg-white rounded-start-pill"><i class="bi bi-link-45deg"></i></span>
                            <input asp-for="UrlImagen" type="url" class="form-control rounded-end-pill">
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Fecha" class="form-label fw-bold">Fecha</label>
                            <input asp-for="Fecha" type="date" class="form-control rounded-pill">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="HoraInicio" class="form-label fw-bold">Hora Inicio</label>
                            <input asp-for="HoraInicio" type="time" class="form-control rounded-pill">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="HoraFin" class="form-label fw-bold">Hora Final</label>
                            <input asp-for="HoraFin" type="time" class="form-control rounded-pill">
                        </div>
                        <div class="col-md-6">
                            <label  asp-for="Precio" class="form-label fw-bold">Precio (COP)</label>
                            <div class="input-group">
                                <span  class="input-group-text bg-white rounded-start-pill">$</span>
                                <input asp-for="Precio" type="number" step="0.01" class="form-control rounded-end-pill">
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Ubicacion" class="form-label fw-bold">Ubicación</label>
                        <input asp-for="Ubicacion" type="text" class="form-control rounded-pill">
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Descripcion" class="form-label fw-bold">Ubicación</label>
                        <textarea asp-for="Descripcion" rows="3" style="border-radius: 15px;" placeholder="Cuéntales de qué trata el evento..."></textarea>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Admin" class="btn btn-light rounded-pill px-4">Volver</a>
                        <button type="submit" class="btn btn-warning rounded-pill px-5 fw-bold shadow-sm">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>